---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Downy Barberstreet' } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Downy Barberstreet - Local barbershop Pandaan dengan vibe street. Potongan rapi, gaya jalanan." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;800&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-white font-body antialiased selection:bg-yellow-400 selection:text-black">
    <slot />
  </body>
</html>

<style>
  html { scroll-behavior: smooth; }
  body { overflow-x: hidden; }
</style>
