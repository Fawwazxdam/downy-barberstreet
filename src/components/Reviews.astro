---
<section id="ulasan" class="py-24 bg-zinc-900 border-y-4 border-yellow-400 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-flex items-center justify-center space-x-2 bg-black px-4 py-2 border-2 border-yellow-400 mb-6 transform rotate-2">
        <Icon name="lucide:star" class="w-6 h-6 text-yellow-400 fill-current" />
        <span class="text-yellow-400 text-2xl font-bebas tracking-widest mt-1">RATING 4.8 / 5.0</span>
      </div>
      <h2 class="text-5xl md:text-7xl font-bebas text-white uppercase tracking-wider">Kata <span class="text-yellow-400">Mereka</span></h2>
    </div>

    <div class="relative" id="review-carousel">
      <div class="overflow-hidden">
        <div class="flex transition-transform duration-500 ease-in-out" id="carousel-track">
          {reviews.map((review, index) => (
            <div class="w-full md:w-1/2 lg:w-1/3 flex-shrink-0 px-4" data-index={index}>
              <div class="bg-black p-8 border-2 border-zinc-800 brutal-shadow-white relative group hover:border-white transition-colors h-full flex flex-col">
                <Icon name="lucide:quote" class="absolute top-6 right-6 w-12 h-12 text-zinc-800 opacity-50 group-hover:text-yellow-400 group-hover:opacity-20 transition-colors" />
                <div class="flex items-center space-x-1 mb-4 relative z-10">
                  {[...Array(review.rating)].map(() => (
                    <Icon name="lucide:star" class="w-5 h-5 text-yellow-400 fill-current" />
                  ))}
                </div>
                <p class="text-zinc-300 font-medium mb-6 relative z-10 uppercase text-sm leading-relaxed tracking-wide line-clamp-5">"{review.text}"</p>
                <div class="mt-auto pt-4 border-t-2 border-zinc-800 relative z-10">
                  <span class="text-yellow-400 font-bebas text-xl tracking-wider">{review.name}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex justify-center mt-8 space-x-3" id="carousel-dots">
        {reviews.map((_, index) => (
          <button
            class="w-3 h-3 rounded-full bg-zinc-700 hover:bg-yellow-400 transition-colors carousel-dot"
            data-index={index}
            aria-label={`Go to review ${index + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  class ReviewCarousel {
    track: HTMLElement;
    dots: HTMLElement[];
    currentIndex: number;
    totalSlides: number;
    autoRotateInterval: number | null;
    visibleSlides: number;

    constructor() {
      this.track = document.getElementById('carousel-track')!;
      this.dots = Array.from(document.querySelectorAll('.carousel-dot'));
      this.currentIndex = 0;
      this.totalSlides = this.dots.length;
      this.autoRotateInterval = null;
      this.visibleSlides = this.getVisibleSlides();

      this.init();
    }

    getVisibleSlides(): number {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 768) return 2;
      return 1;
    }

    getMaxIndex(): number {
      return Math.max(0, this.totalSlides - this.visibleSlides);
    }

    init() {
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          this.goTo(index);
          this.resetAutoRotate();
        });
      });

      this.update();
      this.startAutoRotate();

      window.addEventListener('resize', () => {
        this.visibleSlides = this.getVisibleSlides();
        if (this.currentIndex > this.getMaxIndex()) {
          this.currentIndex = this.getMaxIndex();
        }
        this.update();
      });
    }

    goTo(index: number) {
      this.currentIndex = Math.min(index, this.getMaxIndex());
      this.update();
    }

    next() {
      this.currentIndex = this.currentIndex >= this.getMaxIndex() ? 0 : this.currentIndex + 1;
      this.update();
    }

    update() {
      const slideWidth = 100 / this.visibleSlides;
      this.track.style.transform = `translateX(-${this.currentIndex * slideWidth}%)`;

      this.dots.forEach((dot, index) => {
        if (index === this.currentIndex) {
          dot.classList.add('bg-yellow-400');
          dot.classList.remove('bg-zinc-700');
        } else {
          dot.classList.remove('bg-yellow-400');
          dot.classList.add('bg-zinc-700');
        }
      });
    }

    startAutoRotate() {
      this.autoRotateInterval = window.setInterval(() => this.next(), 4000);
    }

    resetAutoRotate() {
      if (this.autoRotateInterval) {
        clearInterval(this.autoRotateInterval);
      }
      this.startAutoRotate();
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new ReviewCarousel();
  });
</script>

<style>
  .line-clamp-5 {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
