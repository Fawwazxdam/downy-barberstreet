---
import { Icon } from 'astro-icon/components';
---
<section id="kontak" class="py-24 bg-zinc-950 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <div>
        <div class="border-l-4 border-yellow-400 pl-4 mb-10">
          <h2 class="text-5xl md:text-7xl font-bebas text-white uppercase tracking-wider leading-none">Temukan <br/><span class="text-yellow-400">Markas Kami</span></h2>
        </div>
        
        <div class="space-y-8 bg-zinc-900 p-8 border-2 border-zinc-800">
          <div class="flex items-start space-x-6">
            <div class="w-14 h-14 bg-black flex items-center justify-center flex-shrink-0 text-yellow-400 border-2 border-yellow-400 transform -rotate-3">
              <Icon name="lucide:clock" class="w-7 h-7" />
            </div>
            <div>
              <h4 class="text-2xl font-bebas text-white mb-1 tracking-wider">Jam Operasional</h4>
              <p class="text-zinc-400 font-bold uppercase text-sm">Senin - Minggu</p>
              <p class="text-yellow-400 font-bebas text-xl tracking-wider mt-1">08.00 - 21.00</p>
            </div>
          </div>
          
          <div class="flex items-start space-x-6">
            <div class="w-14 h-14 bg-black flex items-center justify-center flex-shrink-0 text-yellow-400 border-2 border-yellow-400 transform rotate-3">
              <Icon name="lucide:map-pin" class="w-7 h-7" />
            </div>
            <div>
              <h4 class="text-2xl font-bebas text-white mb-1 tracking-wider">Lokasi Kami</h4>
              <p class="text-zinc-400 font-bold uppercase text-xs leading-relaxed max-w-sm mt-2">Jl. Juanda Gg. Garuda 2 No.4, RT.03/RW.06, Jabon, Jogosari, Kec. Pandaan, Pasuruan, Jawa Timur 67156.</p>
            </div>
          </div>
        </div>

        <div class="mt-10">
          <a href="https://wa.me/6289606045370" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-8 py-5 text-white font-bebas text-xl tracking-widest uppercase border-2 border-transparent hover:border-yellow-400 brutal-shadow transition-transform w-full md:w-auto justify-center">
            <Icon name="lucide:message-circle" class="w-6 h-6 mr-3" />
            Booking via WhatsApp
          </a>
        </div>
      </div>
      
      <div class="h-96 lg:h-auto min-h-[400px] border-4 border-yellow-400 brutal-shadow relative bg-zinc-900 overflow-hidden">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3954.252758199735!2d112.70046850000001!3d-7.6559493000000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7d9726a95eadf%3A0xeadecab2a69636a4!2sDowny%20barberstreet!5e0!3m2!1sid!2sid!4v1782549813700!5m2!1sid!2sid"
          class="w-full h-full border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
      
    </div>
  </div>
  
  <footer class="mt-24 pt-8 border-t-2 border-zinc-800 text-center px-4 pb-8">
    <div class="flex items-center justify-center space-x-6 mb-6">
      <a href="https://www.instagram.com/barberstreet.pandaan/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="Instagram">
        <Icon name="lucide:instagram" class="w-6 h-6" />
      </a>
      <a href="https://www.tiktok.com/@downy.barberstreet?_r=1&_t=ZS-97YXnRCvd0X" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="TikTok">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.74a8.28 8.28 0 0 0 4.76 1.5v-3.4a4.85 4.85 0 0 1-1-.15z"/></svg>
      </a>
    </div>
    <p class="text-zinc-500 font-bold uppercase text-sm tracking-wider">&copy; {new Date().getFullYear()} Downy Barberstreet. All rights reserved.</p>
  </footer>
</section>
