---
const navLinks = [
  { label: 'Layanan', href: '#layanan' },
  { label: 'Portofolio', href: '#portofolio' },
  { label: 'Ulasan', href: '#ulasan' },
  { label: 'Kontak', href: '#kontak' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <a href="#" class="flex items-center gap-2">
        <svg class="w-7 h-7 sm:w-8 sm:h-8 text-barber-gold" viewBox="0 0 32 32" fill="none">
          <rect x="4" y="2" width="5" height="28" rx="2.5" fill="currentColor" opacity="0.9"/>
          <rect x="11" y="2" width="5" height="28" rx="2.5" fill="currentColor" opacity="0.6"/>
          <rect x="18" y="2" width="5" height="28" rx="2.5" fill="currentColor" opacity="0.3"/>
          <circle cx="26" cy="16" r="5" fill="currentColor"/>
        </svg>
        <span class="font-display font-bold text-lg sm:text-xl tracking-wide text-white">DOWNY</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 text-sm font-medium text-white/70 hover:text-barber-gold transition-colors duration-300 tracking-wider uppercase"
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://wa.me/6289606045370"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-4 px-5 py-2 bg-barber-gold text-barber-dark font-semibold text-sm rounded hover:bg-barber-gold-light transition-all duration-300 tracking-wider uppercase"
        >
          Booking
        </a>
      </div>

      <button
        id="mobile-toggle"
        class="md:hidden text-white p-2"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-barber-dark/95 backdrop-blur-md border-t border-barber-gold/20">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-3 text-sm font-medium text-white/70 hover:text-barber-gold hover:bg-white/5 rounded transition-colors duration-300 tracking-wider uppercase"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/6289606045370"
        target="_blank"
        rel="noopener noreferrer"
        class="block px-4 py-3 bg-barber-gold text-barber-dark font-semibold text-sm rounded text-center tracking-wider uppercase mt-2"
      >
        Booking Sekarang
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      navbar?.classList.add('bg-barber-dark/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/30');
    } else {
      navbar?.classList.remove('bg-barber-dark/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/30');
    }
    lastScroll = currentScroll;
  });

  mobileToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
