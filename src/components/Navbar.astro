---
import { Icon } from 'astro-icon/components';
---
<nav class="sticky top-0 z-50 bg-zinc-950 border-b-2 border-zinc-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <div class="flex-shrink-0">
        <a href="#" class="font-bebas text-3xl tracking-widest text-yellow-400 uppercase">DOWNY BARBERSTREET</a>
      </div>
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href="#layanan" class="font-bebas text-xl tracking-wider text-white hover:text-yellow-400 uppercase transition-colors">Layanan</a>
          <a href="#ulasan" class="font-bebas text-xl tracking-wider text-white hover:text-yellow-400 uppercase transition-colors">Ulasan</a>
          <a href="#kontak" class="font-bebas text-xl tracking-wider text-white hover:text-yellow-400 uppercase transition-colors">Kontak</a>
        </div>
      </div>
      <div class="hidden md:flex items-center space-x-4 ml-6">
        <a href="https://www.instagram.com/barberstreet.pandaan/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="Instagram">
          <Icon name="lucide:instagram" class="w-5 h-5" />
        </a>
        <a href="https://www.tiktok.com/@downy.barberstreet?_r=1&_t=ZS-97YXnRCvd0X" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="TikTok">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.74a8.28 8.28 0 0 0 4.76 1.5v-3.4a4.85 4.85 0 0 1-1-.15z"/></svg>
        </a>
      </div>
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-white hover:text-yellow-400 focus:outline-none">
          <Icon name="lucide:menu" class="h-8 w-8" />
        </button>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-zinc-900 border-b-2 border-yellow-400">
    <div class="px-4 py-4 space-y-4">
      <a href="#layanan" class="font-bebas text-2xl tracking-wider text-white hover:text-yellow-400 block uppercase">Layanan</a>
      <a href="#ulasan" class="font-bebas text-2xl tracking-wider text-white hover:text-yellow-400 block uppercase">Ulasan</a>
      <a href="#kontak" class="font-bebas text-2xl tracking-wider text-white hover:text-yellow-400 block uppercase">Kontak</a>
      <div class="flex items-center space-x-4 pt-4 border-t border-zinc-800">
        <a href="https://www.instagram.com/barberstreet.pandaan/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="Instagram">
          <Icon name="lucide:instagram" class="w-6 h-6" />
        </a>
        <a href="https://www.tiktok.com/@downy.barberstreet?_r=1&_t=ZS-97YXnRCvd0X" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-yellow-400 transition-colors" aria-label="TikTok">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.74a8.28 8.28 0 0 0 4.76 1.5v-3.4a4.85 4.85 0 0 1-1-.15z"/></svg>
        </a>
      </div>
    </div>
  </div>
</nav>
<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if(btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
